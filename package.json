{
  "name": "benford-skills",
  "type": "module",
  "private": true,
  "scripts": {
    "link:local": "bash scripts/link-local-skills.sh",
    "dashboard:refresh": "python3 dashboard/build_snapshot.py",
    "dashboard:link": "bash scripts/link-dashboard-to-vault.sh",
    "router": "bun run scripts/benford-router.ts",
    "automations": "bun run scripts/benford-automations.ts",
    "canonical-editor": "bun run scripts/benford-canonical-editor.ts",
    "backoffice:dev": "bun run apps/backoffice/dev.ts",
    "backoffice:worker": "bun run apps/backoffice/worker.ts",
    "backoffice:worker:openclaw": "OPENCLAW_SSH_TARGET='openclaw' OPENCLAW_REMOTE_COMMAND='openclaw' OPENCLAW_AGENT='prospecting-agent' bun run apps/backoffice/worker.ts",
    "backoffice:sync-openclaw-skills": "bash apps/backoffice/scripts/sync-openclaw-skills.sh",
    "backoffice:test": "bun test tests/backoffice/frontend.test.ts",
    "backoffice:typecheck": "bunx tsc --noEmit -p apps/backoffice/tsconfig.json",
    "test": "bun test",
    "test:router": "bun test tests/router-engine/router-engine.test.ts",
    "test:automations": "bun test tests/proposal-automation/proposal-automation.test.ts",
    "test:canonical-editor": "bun test tests/canonical-editor/canonical-editor.test.ts",
    "lint:router": "bunx biome check src/router-engine scripts/benford-router.ts tests/router-engine/router-engine.test.ts",
    "lint:automations": "bunx biome check src/proposal-automation scripts/benford-automations.ts tests/proposal-automation/proposal-automation.test.ts",
    "lint:canonical-editor": "bunx biome check src/canonical-editor scripts/benford-canonical-editor.ts tests/canonical-editor/canonical-editor.test.ts",
    "typecheck": "bunx tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/bun": "latest",
    "bun-types": "^1.3.11",
    "typescript": "^5"
  }
}
