# Copy to apps/backoffice/.env.local and fill locally. Do not commit real values.

APOLLO_API_KEY=
EXPLORIUM_API_KEY=
PDL_API_KEY=

# Source adapter policy.
BACKOFFICE_SOURCE_ADAPTERS_ENABLED=1
BACKOFFICE_PAID_SOURCES_REQUIRE_BUDGET=1

# Optional cost estimates in USD cents for budget hard stops.
BACKOFFICE_APOLLO_ORG_SEARCH_COST_CENTS=1
BACKOFFICE_APOLLO_PEOPLE_SEARCH_COST_CENTS=0
BACKOFFICE_PDL_PERSON_ENRICH_COST_CENTS=28

# Optional provider base URLs.
APOLLO_BASE_URL=https://api.apollo.io/api/v1
PDL_BASE_URL=https://api.peopledatalabs.com/v5
