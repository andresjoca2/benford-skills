    {
      "id": "tx0300",
      "type": "text",
      "x": 94,
      "y": 1147,
      "width": 1160,
      "height": 81,
      "angle": 0,
      "strokeColor": "#c92a2a",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
