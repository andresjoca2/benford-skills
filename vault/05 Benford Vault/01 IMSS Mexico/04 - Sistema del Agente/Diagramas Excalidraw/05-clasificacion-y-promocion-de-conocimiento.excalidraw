    {
      "id": "tx0298",
      "type": "text",
      "x": 94,
      "y": 992,
      "width": 1844,
      "height": 81,
      "angle": 0,
      "strokeColor": "#2b8a3e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 999452141,
      "version": 1,
      "versionNonce": 255194771,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776835650138,
      "link": null,
      "locked": false,
      "text": "Escalera de promoción\n1 auditor = hipótesis útil | misma firma repetida = patrón local | 2 firmas = candidato serio | 3+ firmas sin contradicción + curador = fuerte candidato a base\nLa promoción nunca es automática: la evidencia ordena la cola, la decisión final sigue siendo humana.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 17,
      "containerId": null,
      "originalText": "Escalera de promoción\n1 auditor = hipótesis útil | misma firma repetida = patrón local | 2 firmas = candidato serio | 3+ firmas sin contradicción + curador = fuerte candidato a base\nLa promoción nunca es automática: la evidencia ordena la cola, la decisión final sigue siendo humana.",
      "lineHeight": 1.25
    },
