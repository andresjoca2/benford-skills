      "seed": 859872154,
      "version": 1,
      "versionNonce": 871559510,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1776835650138,
      "link": null,
      "locked": false,
      "text": "Punto fino\nUn paso puede ser base, pero su tolerancia, umbral o excepción puede seguir siendo variant-specific.\nClasificar la prueba completa sin bajar al nivel de regla rompe el producto.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 17,
      "containerId": null,
      "originalText": "Punto fino\nUn paso puede ser base, pero su tolerancia, umbral o excepción puede seguir siendo variant-specific.\nClasificar la prueba completa sin bajar al nivel de regla rompe el producto.",
      "lineHeight": 1.25
    },
