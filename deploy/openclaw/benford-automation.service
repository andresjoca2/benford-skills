[Unit]
Description=Benford central automation runner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.config/benford/automation.env
ExecStart=/bin/bash %h/benford/benford-skills/deploy/openclaw/run-benford-automation.sh
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
